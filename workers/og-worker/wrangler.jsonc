{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "eqmonitor-og-worker",
  "main": "src/index.tsx",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "workers_dev": false,
  "rules": [
    {
      "type": "Data",
      "globs": ["**/*.ttf"],
      "fallthrough": true
    }
  ]
}
