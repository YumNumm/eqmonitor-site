{
  "name": "eqmonitor-site",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "portless eqmonitor-site pnpm vite dev",
    "build": "vite build",
    "preview": "portless eqmonitor-site vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply eqmonitor-site-inquiries --local",
    "db:migrate:remote": "wrangler d1 migrations apply eqmonitor-site-inquiries --remote"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@shikijs/rehype": "^4.3.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.8",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.14",
    "eqmonitor-beta-worker": "workspace:*",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.23",
    "jose": "^6.2.3",
    "marked": "^16.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.3.0",
    "unified": "^11.0.5",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.39.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "daisyui": "^5.5.19",
    "portless": "^0.13.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "wrangler": "^4.95.0"
  }
}
