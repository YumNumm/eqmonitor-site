{
  "name": "eqmonitor-site",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "postinstall": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply eqmonitor-site-inquiries --local",
    "db:migrate:remote": "wrangler d1 migrations apply eqmonitor-site-inquiries --remote"
  },
  "dependencies": {
    "@better-auth-ui/core": "^1.6.17",
    "@better-auth-ui/heroui": "^1.6.17",
    "@better-auth-ui/react": "^1.6.17",
    "@gravity-ui/icons": "^2.18.0",
    "@heroicons/react": "^2.2.0",
    "@heroui/react": "^3.1.0",
    "@heroui/styles": "^3.1.0",
    "@internationalized/date": "^3.12.2",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.8",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.14",
    "better-auth": "^1.6.14",
    "bowser": "^2.14.1",
    "eqmonitor-beta-worker": "workspace:*",
    "jose": "^6.2.3",
    "marked": "^16.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.39.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "wrangler": "^4.95.0"
  }
}
